{
	"name": "@amos.com/react-amos-js",
	"version": "0.3.1",
	"main": "dist/index.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/amos/react-amos-js"
	},
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"biome": "biome check --write",
		"dev": "vite",
		"prebuild": "npm run typecheck",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"prepack": "npm run build",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "npm run build && changeset publish"
	},
	"author": "Amos",
	"description": "React SDK for embedding Amos payment methods via iframes. Wraps @amos.com/amos-js.",
	"devDependencies": {
		"@changesets/cli": "2.31.0",
		"@biomejs/biome": "2.4.15",
		"@types/node": "25.9.1",
		"@types/react": "19.2.15",
		"typescript": "6.0.3",
		"vite": "7.3.3",
		"vite-plugin-dts": "4.5.4"
	},
	"dependencies": {
		"@amos.com/amos-js": "0.3.1",
		"@amos.com/node": "0.1.6",
		"@types/googlepay": "0.7.10"
	},
	"peerDependencies": {
		"react": "^17 || ^18 || ^19"
	}
}
